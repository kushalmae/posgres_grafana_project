          "rawQuery": true,
          "rawSql": "SELECT a.observed_at AS time, ROUND(CAST(a.signal_value - b.signal_value AS numeric), 3) AS value, 'Sat-A minus Sat-B (battery_voltage)' AS metric FROM telemetry_history a JOIN telemetry_history b ON date_trunc('second', a.observed_at) = date_trunc('second', b.observed_at) AND b.spacecraft = 'Sat-B' AND b.signal_name = 'battery_voltage' WHERE $__timeFilter(a.observed_at) AND a.spacecraft = 'Sat-A' AND a.signal_name = 'battery_voltage' ORDER BY a.observed_at;",
